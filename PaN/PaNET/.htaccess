Header set Access-Control-Allow-Origin *
Options +FollowSymLinks
RewriteEngine On

# Root: redirect to latest
RewriteRule ^$ https://github.com/ExPaNDS-eu/ExPaNDS-experimental-techniques-ontology/releases/latest [R=303,L]

# Versioned ontologies, e.g., /v0.1.0/, /v0.2.1/
RewriteRule ^v([0-9]+\.[0-9]+\.[0-9]+)\/?$ https://github.com/ExPaNDS-eu/ExPaNDS-experimental-techniques-ontology/v$1/ [R=303,L,NC]

# Everything else, redirect to latest with path preserved
RewriteRule ^(.+)$ https://expands-eu.github.io/ExPaNDS-experimental-techniques-ontology/index-en.html#$1 [R=303,L]
